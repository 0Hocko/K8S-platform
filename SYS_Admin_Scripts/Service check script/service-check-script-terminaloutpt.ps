# Check the status of each service
foreach ($service in $services) {
    $status = Get-Service -Name $service -ErrorAction SilentlyContinue
    if ($status) {
        Write-Output "$service: $($status.StartType)"
    } else {
        Write-Output "$service: Service not found"
    }
}
